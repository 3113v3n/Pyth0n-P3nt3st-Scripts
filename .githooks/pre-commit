#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [[ -x "$ROOT/.venv/bin/python" ]]; then
  PYTHON_BIN="$ROOT/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python3)"
else
  echo "[SECURITY GATE] python3 not found; cannot run security checks."
  exit 1
fi

echo "[SECURITY GATE] Running staged-change checks..."
"$PYTHON_BIN" "$ROOT/scripts/security_gate.py" --staged
